# Configuración de Firebase para el modo Online (Realtime Database).
# Copia este archivo como .env (local) y/o pon estas variables en Vercel.
# Sin estas variables, el online usa un modo de prueba entre pestañas del mismo dispositivo.

VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_DB_URL=
VITE_FB_PROJECT_ID=
VITE_FB_APP_ID=
